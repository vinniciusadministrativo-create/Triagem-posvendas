# =======================================================
# VARIÁVEIS DE AMBIENTE — Backend Triagem Pós-Vendas Marin
# Copie para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no Git.
# =======================================================

# ── Banco de dados PostgreSQL ──────────────────────────
# Obtenha no Railway (ou Azure Database for PostgreSQL)
# OBRIGATÓRIA: o servidor encerra no boot (exit 1) se estiver ausente.
DATABASE_URL=postgresql://usuario:senha@host:5432/marin_triagem

# ── Autenticação JWT ───────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# OBRIGATÓRIA: o servidor encerra no boot (exit 1) se estiver ausente.
JWT_SECRET=substitua_por_uma_string_longa_e_aleatoria_minimo_64_chars

# ── Servidor ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS — URL do frontend ─────────────────────────────
# Em produção: URL do seu Azure App Service ou domínio customizado
FRONTEND_URL=http://localhost:5173

# ── Cloudinary (upload de arquivos) ───────────────────
# Obtenha em https://cloudinary.com → Dashboard → API Keys
# ATENÇÃO: Nunca use fallback hardcoded no código.
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ── IAs ────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini
ANTHROPIC_API_KEY=sua_chave_anthropic

# ── Extração de NF (script Python) — opcional ──────────
# Protege o servidor de PDFs travados/picos de carga.
PYTHON_TIMEOUT_MS=30000        # timeout por processo (mata o Python ao exceder)
PYTHON_MAX_CONCURRENCY=4       # máx. de processos Python simultâneos (fila o resto)

# ── E-mail (notificações automáticas) ──────────────────
# Deixe em branco para desativar o envio de e-mails.
# Use o SMTP do seu provedor (ex: Locaweb, Gmail, Zoho, SendGrid).
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=posvendas@marinlog.com.br
SMTP_PASS=senha_do_email
SMTP_FROM=posvendas@marinlog.com.br

# ── Backup automático agendado (opcional) ──────────────
# Envia o dump .sql por e-mail. Desligado por padrão (o anexo contém dados
# sensíveis, incluindo hashes de senha). Requer SMTP.
BACKUP_CRON_ENABLED=false
BACKUP_CRON_SCHEDULE=0 3 * * 1
TZ=America/Sao_Paulo
# Destinatários do backup. Se definido, envia SÓ para estes e-mails (separados
# por vírgula). Se vazio, envia para todos os admins ativos com e-mail.
BACKUP_RECIPIENTS=posvendas@marinlog.com.br
