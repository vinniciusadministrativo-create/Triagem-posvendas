# Variáveis de ambiente do backend
# Copie este arquivo para .env e preencha com os seus valores

# Banco de dados PostgreSQL (obtenha do Railway após provisionar)
DATABASE_URL=postgresql://usuario:senha@host:5432/marin_triagem

# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=substitua_por_uma_string_longa_e_aleatoria

# Porta do servidor (Railway define automaticamente)
PORT=3001

# URL do frontend (para CORS — URL da Vercel após deploy)
FRONTEND_URL=https://seu-app.vercel.app

# Google Gemini API Key (gratuito em https://aistudio.google.com)
GEMINI_API_KEY=sua_chave_gemini_aqui

# Ambiente
NODE_ENV=development
